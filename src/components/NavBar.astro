---
import styles from './NavBar.module.scss';
const currentPath = Astro.url.pathname;
---

<div
	class={`${styles.navBarWrapper} ${currentPath === '/history' ? styles.borderActive : ''}`}
>
	<span
		style='font-size:10px; position:fixed; top:0; right:0; background:red; color:white; z-index:9999'
	>
		{Astro.url.pathname}
	</span>
	<div class={styles.imgWrapper}>
		<a href='/' class={`${currentPath === '/' ? styles.activeImg : ''}`}
			><img
				class={styles.img}
				src={currentPath === '/' ? 'invertcircle.webp' : 'circle.webp'}
				alt=''
			/></a
		>
	</div>
	<a
		href='/self'
		class={`${styles.gridItem} ${currentPath === '/self' ? styles.active : ''}`}
		>SELF</a
	>
	<a
		href='/creations'
		class={`${styles.gridItem} ${currentPath === '/creations' ? styles.active : ''}`}
		>CREATIONS</a
	>
	<a
		href='/history'
		class={`${styles.gridItem} ${currentPath === '/history' ? styles.active : ''} ${styles.history}`}
		>HISTORY</a
	>
</div>
